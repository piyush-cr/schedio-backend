# Server
NODE_ENV=production
PORT=3000

# MongoDB (replica set for transactions)
MONGODB_URI=mongodb://user:pass@host1:27017,host2:27017,host3:27017/db?replicaSet=rs0

# Upstash Redis – used for rate limiting, worker cache, and BullMQ (worker)
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Optional: override BullMQ TCP connection (if derived from Upstash fails)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ImageKit (optional)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
