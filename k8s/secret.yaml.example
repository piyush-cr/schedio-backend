# Copy to secret.yaml and fill in real values. Do NOT commit secret.yaml.
# Create with: kubectl create secret generic schedio-secrets --from-env-file=.env.prod -n schedio
# Or apply this file after base64-encoding values:
#
# apiVersion: v1
# kind: Secret
# metadata:
#   name: schedio-secrets
#   namespace: schedio
# type: Opaque
# stringData:
#   MONGODB_URI: "mongodb://user:pass@host:27017/db?authSource=admin"
#   UPSTASH_REDIS_REST_URL: "https://xxx.upstash.io"
#   UPSTASH_REDIS_REST_TOKEN: "your-token"
#   # Optional: REDIS_URL for BullMQ if derived connection fails
#   JWT_SECRET: "your-jwt-secret"
#   JWT_REFRESH_SECRET: "your-refresh-secret"
#   # Optional: Firebase, ImageKit, etc.
#   FIREBASE_PROJECT_ID: ""
#   FIREBASE_CLIENT_EMAIL: ""
#   FIREBASE_PRIVATE_KEY: ""
